<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tab_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:textColor="@color/psd_color_bluegray_550"
        android:textSize="18sp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="White Rabbit" />

    <View
        android:id="@+id/tab_line"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@color/psd_accent"
        app:layout_constraintEnd_toEndOf="@id/tab_text"
        app:layout_constraintStart_toStartOf="@id/tab_text"
        app:layout_constraintTop_toBottomOf="@id/tab_text" />

</androidx.constraintlayout.widget.ConstraintLayout>