<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/psd_background"
    android:clipToPadding="false"
    android:clipChildren="false"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_rv">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tickets_rv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="@dimen/psd_recyclerView_offset"
            android:overScrollMode="never"
            android:clipToPadding="false"/>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>


    <include
        android:id="@+id/toolbar_tickets_list"
        layout="@layout/psd_toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/psd_toolbar_height"
        android:background="@color/psd_background"
        app:contentInsetLeft="0dp"
        app:contentInsetStart="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:title="ikko" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tab_rv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/psd_offset_default"
        android:visibility="gone"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:background="@color/psd_background"

        app:layout_constraintTop_toBottomOf="@+id/toolbar_tickets_list"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/psd_accent"
        app:tabIndicatorHeight="2dp"
        app:tabMode="scrollable"
        app:tabSelectedTextColor="@color/psd_accent"
        app:tabTextAppearance="@style/PsdTabStyle"
        app:tabTextColor="@color/psd_color_bluegray_550" />

    <View
        android:id="@+id/content_divider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/psd_color_divider_300"
        app:layout_constraintBottom_toBottomOf="@+id/tab_rv" />


    <ImageButton
        android:id="@+id/psd_empty_list_ib"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/ic_chat"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/createTicketTv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <TextView
        android:id="@+id/createTicketTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Создать обращение"
        android:textColor="#354DF2"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/fabAddTicket"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_tickets_list" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddTicket"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:src="@drawable/ic_add_big"
        android:visibility="visible"
        android:layout_marginEnd="@dimen/psd_offset_default"
        android:layout_marginBottom="68dp"
        app:fabSize="normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="ContentDescription" />

    <include
        android:id="@+id/no_connection"
        layout="@layout/psd_no_connection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_tickets_list" />

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="@dimen/psd_recyclerview_item_height_default"
        android:layout_height="@dimen/psd_recyclerview_item_height_default"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_tickets_list" />

</androidx.constraintlayout.widget.ConstraintLayout>