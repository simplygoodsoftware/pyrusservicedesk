<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:id="@+id/root"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="bottom|end"
    android:orientation="horizontal">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/statusIcon"
        android:layout_width="@dimen/psd_comment_error_width"
        android:layout_height="wrap_content"
        android:forceDarkAllowed="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:srcCompat="@tools:sample/avatars" />

    <androidx.cardview.widget.CardView
        android:id="@+id/background_parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/psd_comment_radius"
        app:cardElevation="0dp"
        app:cardPreventCornerOverlap="false">

        <com.pyrus.pyrusservicedesk.presentation.ui.view.ImFlexboxLayout
            android:id="@+id/comment_text_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:viewPartMain="@+id/comment_text"
            android:paddingStart="@dimen/dp_12"
            android:paddingLeft="@dimen/dp_12"
            android:paddingEnd="@dimen/dp_12"
            android:paddingRight="@dimen/dp_12"
            android:paddingTop="@dimen/psd_offset_small"
            android:paddingBottom="@dimen/psd_offset_small"
            android:visibility="gone"
            app:viewPartSlave="@+id/text_time"
            tools:visibility="visible">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/comment_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceListItem"
                android:textSize="17sp"
                tools:text="@tools:sample/lorem" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/text_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceListItem"
                android:textSize="13sp"
                android:maxLines="1"
                android:translationY="5dp"
                android:paddingBottom="2dp"
                android:paddingStart="@dimen/psd_offset_small"
                android:paddingLeft="@dimen/psd_offset_small"
                tools:text="@tools:sample/date/hhmm"/>


        </com.pyrus.pyrusservicedesk.presentation.ui.view.ImFlexboxLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
