<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ticket_toolbar"
    android:layout_width="match_parent"
    android:layout_height="52sp"
    android:background="@color/psd_background"
    android:paddingHorizontal="@dimen/psd_offset_small">

    <LinearLayout
        android:id="@+id/titleLl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="34dp"
        android:layout_marginEnd="@dimen/psd_elevation_default"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/psd_search_ib"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/psd_toolbar_vendor_iv"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical" />

        <TextView
            android:id="@+id/psd_toolbar_vendor_name_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/psd_elevation_default"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/psd_text_primary"
            android:textSize="@dimen/psd_text_20"
            android:textStyle="bold"
            tools:text="ikko ikko ikko ikko ikko ikko ikko ikko ikko ikko ikko" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/psd_search_ib"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="@dimen/psd_offset_small"
        android:src="@drawable/psd_ic_search"
        app:layout_constraintBottom_toBottomOf="@+id/titleLl"
        app:layout_constraintEnd_toStartOf="@id/psd_toolbar_right_ib"
        app:layout_constraintTop_toTopOf="@+id/titleLl" />

    <ImageButton
        android:id="@+id/psd_toolbar_right_ib"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:visibility="gone"
        android:padding="@dimen/psd_offset_small"
        app:layout_constraintBottom_toBottomOf="@+id/titleLl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/titleLl"
        tools:src="@drawable/ic_qr"
        tools:visibility="visible" />


</androidx.constraintlayout.widget.ConstraintLayout>